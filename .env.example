# Local development only. Copy to .env and fill in real values.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3
OPENAI_MAX_ROWS=60
OPENAI_BATCH_SIZE=20
OPENAI_TIMEOUT_MS=45000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
SESSION_SECRET=replace-with-a-long-random-string
ALLOWED_EMAIL_DOMAIN=nationalpositions.com
# Optional comma-separated email allowlist in addition to ALLOWED_EMAIL_DOMAIN.
ALLOWED_EMAILS=
